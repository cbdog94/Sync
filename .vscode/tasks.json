{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: Install",
      "type": "shell",
      "command": "pnpm install",
      "options": { "cwd": "${workspaceFolder}/Sync.Frontend" },
      "problemMatcher": []
    },
    {
      "label": "Frontend: Build",
      "type": "shell",
      "command": "pnpm build",
      "options": { "cwd": "${workspaceFolder}/Sync.Frontend" },
      "dependsOn": "Frontend: Install",
      "problemMatcher": []
    },
    {
      "label": "Frontend: Dev",
      "type": "shell",
      "command": "pnpm dev",
      "options": { "cwd": "${workspaceFolder}/Sync.Frontend" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "Backend: Build",
      "type": "shell",
      "command": "dotnet build",
      "options": { "cwd": "${workspaceFolder}/Sync.Backend" },
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Backend: Run",
      "type": "shell",
      "command": "dotnet run",
      "options": { "cwd": "${workspaceFolder}/Sync.Backend" },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Building",
          "endsPattern": "Now listening on"
        }
      }
    },
    {
      "label": "Build All",
      "dependsOn": ["Frontend: Build", "Backend: Build"],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Run All (Dev)",
      "dependsOn": ["Backend: Run", "Frontend: Dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
